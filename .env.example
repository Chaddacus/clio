# Backend Configuration
SECRET_KEY=your-very-secure-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=voice_notes_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5435

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Whisper Transcription Configuration
WHISPER_MODEL=whisper-1
WHISPER_TEMPERATURE=0
WHISPER_FORMAT_TEXT=true
WHISPER_PARAGRAPH_BREAK_SECONDS=2.0
WHISPER_MAX_SENTENCE_LENGTH=150

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8011/api

# Production Settings (for docker-compose.prod.yml)
# SECRET_KEY=your-production-secret-key
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DB_PASSWORD=your-secure-db-password